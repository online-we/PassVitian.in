# Cloudinary (frontend – safe to expose in build)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset
# Optional: if you use a separate preset for PDFs (Raw), set it here; otherwise same as above
# VITE_CLOUDINARY_UPLOAD_PRESET_RAW=your_unsigned_raw_preset

# Netlify sets these for the serverless function (do not put in frontend)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# Optional: for production API base URL (Netlify sets this automatically)
# VITE_SITE_URL=https://your-site.netlify.app
